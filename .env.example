# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment variable template
# Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ── LLM ───────────────────────────────────────────────────────────────────────
MODEL_NAME=groq:llama-3.3-70b-versatile

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Course Advisor Agent
DEBUG=false

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu           # use "cuda" on GPU machines

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=simple    # simple | chroma | qdrant

# Chroma (only needed if VECTOR_STORE_BACKEND=chroma)
# CHROMA_HOST=                 # leave empty for in-process mode
# CHROMA_PORT=8000
# CHROMA_COLLECTION=kayfa_knowledge
# CHROMA_PERSIST_DIR=./storage/chroma

# Qdrant (only needed if VECTOR_STORE_BACKEND=qdrant)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=              # leave empty for local Qdrant
# QDRANT_COLLECTION=kayfa_knowledge

# ── Storage ───────────────────────────────────────────────────────────────────
INDEX_STORAGE_PATH=storage/index   # use /data/index on HF Spaces
# Pre-built index in repo (default: {DATA_DIR}/index). Copied to INDEX_STORAGE_PATH on HF cold start.
# BUNDLED_INDEX_PATH=data/index
DATA_DIR=data

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
BM25_TOP_K=8
RERANK_TOP_K=4

# ── Reranker ──────────────────────────────────────────────────────────────────
RERANKER_BACKEND=              # leave empty to disable; bge | cohere
# COHERE_API_KEY=              # only needed if RERANKER_BACKEND=cohere

# ── Deployment ────────────────────────────────────────────────────────────────
IS_HF_SPACES=false             # set true in HF Spaces secrets

# ── CRM / MongoDB ─────────────────────────────────────────────────────────────
# Leave empty for in-memory CRM (local dev). Set for production ticket storage.
# MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=kayfa_crm
MONGODB_COLLECTION=tickets

# ── Session memory ────────────────────────────────────────────────────────────
SESSION_MAX_MESSAGES=20
SESSION_LLM_TURNS=3
SESSION_ANALYSIS_USER_MESSAGES=6
SESSION_ASSISTANT_HISTORY_CHARS=500

# ── Agent / Groq performance ───────────────────────────────────────────────────
# 0 = no Groq SDK retry on 429 (fail fast instead of 10–60s Retry-After waits)
GROQ_MAX_RETRIES=0
GROQ_REQUEST_TIMEOUT_S=45
AGENT_TOOL_CALLS_LIMIT=2
AGENT_REQUEST_LIMIT=6
AGENT_TOOL_RETRIES=2

# ── Authentication (JWT) ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7
# Set true for local dev without login (tests use this)
AUTH_DISABLED=false
